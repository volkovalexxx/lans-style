generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id                 Int                @id @default(autoincrement())
  slug               String             @unique
  nameRu             String
  nameEn             String
  image              String?
  order              Int                @default(0)
  products           Product[]
  additionalProducts ProductCategory[]
  homeCards          HomeCategoryCard[]
  createdAt          DateTime           @default(now())
}

model Product {
  id         Int         @id @default(autoincrement())
  slug       String      @unique
  sku        String?
  nameRu     String
  nameEn     String
  descRu     String?
  descEn     String?
  priceByn   Decimal
  priceUsd   Decimal
  priceRub   Decimal     @default(0)
  sizes      String[]
  colors     String[]
  labels     String[]
  images     String[]
  inStock    Boolean     @default(true)
  isNew      Boolean     @default(false)
  categoryId Int
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())

  isCostume            Boolean           @default(false)
  isArchived           Boolean           @default(false)
  additionalCategories ProductCategory[]
  costumeTopId     Int?
  costumeBottomId  Int?
  costumeItem3Id   Int?
  costumeItem4Id   Int?
  costumeItem5Id   Int?
  costumeTop       Product?  @relation("CostumeTop",    fields: [costumeTopId],    references: [id], onDelete: SetNull)
  costumeBottom    Product?  @relation("CostumeBottom", fields: [costumeBottomId], references: [id], onDelete: SetNull)
  costumeItem3     Product?  @relation("CostumeItem3",  fields: [costumeItem3Id],  references: [id], onDelete: SetNull)
  costumeItem4     Product?  @relation("CostumeItem4",  fields: [costumeItem4Id],  references: [id], onDelete: SetNull)
  costumeItem5     Product?  @relation("CostumeItem5",  fields: [costumeItem5Id],  references: [id], onDelete: SetNull)
  usedAsTop        Product[] @relation("CostumeTop")
  usedAsBottom     Product[] @relation("CostumeBottom")
  usedAsItem3      Product[] @relation("CostumeItem3")
  usedAsItem4      Product[] @relation("CostumeItem4")
  usedAsItem5      Product[] @relation("CostumeItem5")
}

model Order {
  id        Int         @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  comment   String?
  status    String      @default("new")
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  size      String?
  color     String?
  quantity  Int     @default(1)
}

model WholesaleRequest {
  id        Int      @id @default(autoincrement())
  company   String
  name      String
  phone     String
  email     String
  city      String?
  comment   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model PageVisit {
  id        Int      @id @default(autoincrement())
  page      String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  login    String @unique
  password String
}

model ProductCategory {
  productId  Int
  categoryId Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([productId, categoryId])
}

model HomeCategoryCard {
  id          Int       @id @default(autoincrement())
  position    Int       @unique
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  imageUrl    String?
  imageSource String    @default("latest")
}

model SitePage {
  id        Int     @id @default(autoincrement())
  slug      String  @unique
  titleRu   String
  titleEn   String
  contentRu String?
  contentEn String?
  isActive  Boolean @default(true)
}
