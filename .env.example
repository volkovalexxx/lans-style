# PostgreSQL
POSTGRES_DB=lans_style
POSTGRES_USER=lans
POSTGRES_PASSWORD=lans_secret
DATABASE_URL=postgresql://lans:lans_secret@localhost:5432/lans_style

# pgAdmin
PGADMIN_EMAIL=admin@lans.by
PGADMIN_PASSWORD=admin

# Server
PORT=5000
JWT_SECRET=change-me-to-random-string
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@lans-style.by
ORDER_EMAIL=orders@lans-style.by

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Client
VITE_API_URL=http://localhost:5000/api
